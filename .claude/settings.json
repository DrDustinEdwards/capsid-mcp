{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/no-em-dash.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/scoped-git-add.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && npm run -s check 2>&1 | tail -20; exit ${PIPESTATUS[0]}"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(npx tsc *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git show *)",
      "Bash(git log *)",
      "Bash(git branch*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm run deploy*)",
      "Bash(npx wrangler deploy*)",
      "Bash(npx wrangler secret*)",
      "Bash(npx wrangler d1 execute *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Read(./.env*)",
      "Read(./.dev.vars)",
      "Read(./wrangler.jsonc)"
    ]
  }
}
