{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "capsid",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "keep_vars": true,
  "observability": { "enabled": true },
  "triggers": { "crons": ["0 9 * * *"] },
  // Non-secret vars. The GitHub App client id is public; the App private key and
  // installation id are set with `wrangler secret put` and never committed:
  //   wrangler secret put GITHUB_APP_PRIVATE_KEY       (paste the .pem contents)
  //   wrangler secret put GITHUB_APP_INSTALLATION_ID   (optional; auto-resolved if omitted)
  "vars": {
    "GITHUB_APP_CLIENT_ID": "YOUR_GITHUB_APP_CLIENT_ID"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "capsid",
      "database_id": "YOUR_D1_ID",
      "migrations_dir": "migrations"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "APP_KV",
      "id": "YOUR_KV_ID"
    },
    {
      "binding": "OAUTH_KV",
      "id": "YOUR_KV_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "YOUR_R2_BUCKET"
    }
  ]
}
